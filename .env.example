# ─────────────────────────────────────────────────────────────
# ChoirGrid — environment template
# Copy to `.env.local` (gitignored) and fill in real values.
# NEVER commit real secrets. Only VITE_-prefixed vars reach the
# browser bundle, so put ONLY publishable values here.
# The Supabase service-role key must live ONLY in Edge Function
# secrets / CI secrets — never in any VITE_ variable.
# ─────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase ANON / publishable key (safe to expose to the browser).
VITE_SUPABASE_ANON_KEY=

# Toggle mock services for local development (no backend needed).
# 'true'  → in-memory mock data
# 'false' → real Supabase backend (default in CI/production)
VITE_USE_MOCK_SERVICES=true

# Build/version stamp (CI sets this to the commit SHA).
VITE_APP_VERSION=dev
